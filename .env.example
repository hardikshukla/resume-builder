# ── Default LLM Provider ─────────────────────────────────────────
# Options: anthropic | openai | ollama
DEFAULT_LLM_PROVIDER=anthropic

# ── Anthropic (Primary) ──────────────────────────────────────────
ANTHROPIC_MODEL=claude-haiku-4-5

# ── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Resume Builder
NEXT_PUBLIC_APP_VERSION=1.0.0

# ── Sentry Error Tracking (T7.1 — optional) ──────────────────────
# Create a project at https://sentry.io and paste the DSN below.
# Without this, Sentry initialises in no-op mode — nothing breaks.
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@oN.ingest.sentry.io/yyy
# SENTRY_DSN=https://xxx@oN.ingest.sentry.io/yyy  # server-only fallback
# SENTRY_ORG=your-org-slug    # for source map upload in CI
# SENTRY_PROJECT=resume-builder
